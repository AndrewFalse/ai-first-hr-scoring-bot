# Telegram
BOT_TOKEN=your_telegram_bot_token

# OpenRouter API (https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=anthropic/claude-sonnet-4
OPENROUTER_AUDIO_MODEL=openai/gpt-audio-mini

# GitHub
GITHUB_TOKEN=your_github_personal_access_token

# Google Sheets
GOOGLE_SHEETS_CREDENTIALS=credentials.json
GOOGLE_SHEET_ID=your_google_sheet_id

# Admin
ADMIN_SECRET_HASH=generated_unique_hash_here
INIT_ADMIN_SECRET=one_time_init_token
RECRUITER_CHAT_ID=telegram_chat_id_for_notifications

# Database
DB_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://bot:change_me_strong_password@localhost:5432/hr_screening

# Scoring
HOT_THRESHOLD=21
# Hot threshold из /30: кандидат считается горячим если total_score >= HOT_THRESHOLD
